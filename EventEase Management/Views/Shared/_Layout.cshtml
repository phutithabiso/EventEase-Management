<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3f37c9;
            --sidebar-width: 250px;
            --sidebar-collapsed-width: 80px;
            --transition-speed: 0.3s;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8fafc;
            overflow-x: hidden;
        }

        #sidebar {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            color: white;
            height: 100vh;
            width: var(--sidebar-width);
            position: fixed;
            transition: all var(--transition-speed) ease;
            z-index: 1000;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
        }

        .sidebar-header {
            padding: 1.5rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
        }

            .sidebar-header h4 {
                color: white;
                font-weight: 600;
                margin: 0;
                transition: all var(--transition-speed) ease;
            }

        .sidebar-collapsed .sidebar-header h4 {
            opacity: 0;
            width: 0;
        }

        .list-unstyled {
            padding: 1rem 0;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.7);
            padding: 0.75rem 1.5rem;
            margin: 0.25rem 0;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            transition: all 0.2s;
        }

            .nav-link:hover {
                color: white;
                background: rgba(255, 255, 255, 0.1);
                text-decoration: none;
            }

            .nav-link.active {
                color: white;
                background: var(--primary-color);
                font-weight: 500;
            }

            .nav-link i {
                margin-right: 1rem;
                font-size: 1.25rem;
                width: 24px;
                text-align: center;
            }

        .sidebar-collapsed .nav-link span {
            display: none;
        }

        .sidebar-collapsed .nav-link i {
            margin-right: 0;
            font-size: 1.5rem;
        }

        .sidebar-collapsed {
            width: var(--sidebar-collapsed-width);
            text-align: center;
        }

        .main-content {
            margin-left: var(--sidebar-width);
            padding: 1.5rem;
            transition: all var(--transition-speed) ease;
            min-height: calc(100vh - 60px);
        }

        .sidebar-collapsed + .main-content {
            margin-left: var(--sidebar-collapsed-width);
        }

        .toggle-btn {
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: fixed;
            bottom: 20px;
            left: calc(var(--sidebar-width) - 50px);
            z-index: 1001;
            cursor: pointer;
            transition: all var(--transition-speed) ease;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        }

        .sidebar-collapsed .toggle-btn {
            left: calc(var(--sidebar-collapsed-width) - 50px);
        }

        .toggle-btn:hover {
            background: var(--secondary-color);
            transform: scale(1.1);
        }

        footer {
            margin-left: var(--sidebar-width);
            transition: all var(--transition-speed) ease;
        }

        .sidebar-collapsed + footer {
            margin-left: var(--sidebar-collapsed-width);
        }

        @@media (max-width: 768px) {
            #sidebar {
                width: var(--sidebar-collapsed-width);
                text-align: center;
            }

            .sidebar-header h4 {
                display: none;
            }

            .nav-link span {
                display: none;
            }

            .nav-link i {
                margin-right: 0;
                font-size: 1.5rem;
            }

            .main-content {
                margin-left: var(--sidebar-collapsed-width);
            }

            .toggle-btn {
                display: none;
            }
        }
    </style>
    @RenderSection("Styles", false)
</head>
<body>
    <!-- Sidebar -->
    <nav id="sidebar" class="d-flex flex-column">
        <div class="sidebar-header">
            <h4>EventEase Manager</h4>
        </div>
        <ul class="list-unstyled flex-grow-1">
            <li>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid"></i> <span>Dashboard</span>
                </a>
            </li>
            <li>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Venue" ? "active" : "")"
                   asp-controller="Venue" asp-action="Venuebook">
                    <i class="bi bi-building"></i> <span>Venues</span>
                </a>
            </li>
            <li>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Event" ? "active" : "")"
                   asp-controller="Event" asp-action="ListEvent">
                    <i class="bi bi-calendar-event"></i> <span>Events</span>
                </a>
            </li>
            <li>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Booking" ? "active" : "")"
                   asp-controller="Booking" asp-action="BookDetails">
                    <i class="bi bi-book"></i> <span>Bookings</span>
                </a>
            </li>
        </ul>
        <button class="toggle-btn" id="sidebarCollapse">
            <i class="bi bi-chevron-left"></i>
        </button>

    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {

            if ($(window).width() <= 768) {
                $('#sidebar').addClass('sidebar-collapsed');
                $('.main-content').addClass('sidebar-collapsed');
                $('footer').addClass('sidebar-collapsed');
            }
        });
    </script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>